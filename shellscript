#!/bin/bash

API_KEY="${GEMINI_API_KEY:-}"
MODEL="gemini-1.5-flash"


SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MEMORY_FILE="${SCRIPT_DIR}/agent_memory.txt"


SYSTEM_PROMPT=$(cat <<'SYSPROMPT'
You are a cautious and knowledgeable DevOps assistant running on a Linux system.
Your sole task is to translate a user's natural language intent into exactly ONE
safe, executable bash command.

Hard rules you must ALWAYS follow:
1. Prefer non-destructive, read-only commands wherever possible.
2. Never generate commands that delete, overwrite, or irreversibly modify files
   unless the user has explicitly asked for it.
3. Never use sudo or escalate privileges unless the user explicitly requests it.
4. Return ONLY the raw bash command — absolutely no markdown, no backticks,
   no explanations, no comments, no extra text of any kind.
5. The output must be a single line that can be directly passed to eval in bash.
6. If the intent is ambiguous or potentially dangerous, choose the safest
   possible interpretation.
SYSPROMPT
)

# ── ADD-ON 2: Long-Term Memory ───────────────────────────────────

load_memory() {
    if [[ -f "${MEMORY_FILE}" ]]; then
        cat "${MEMORY_FILE}"
    fi
}

# ── LLM Query ────────────────────────────────────────────────────
query_llm() {
    local user_intent="$1"
    local memory_content
    memory_content=$(load_memory)


    local user_message
    if [[ -n "${memory_content}" ]]; then
        user_message="$(printf 'User personal preferences and system context (long-term memory):\n%s\n\nUser intent: %s' \
            "${memory_content}" "${user_intent}")"
    else
        user_message="User intent: ${user_intent}"
    fi

    local api_url="https://generativelanguage.googleapis.com/v1beta/models/${MODEL}:generateContent?key=${API_KEY}"

    
    local payload
    payload=$(jq -n \
        --arg sys "${SYSTEM_PROMPT}" \
        --arg usr "${user_message}" \
        '{
            "system_instruction": {
                "parts": [{ "text": $sys }]
            },
            "contents": [
                {
                    "parts": [{ "text": $usr }]
                }
            ],
            "generationConfig": {
                "temperature": 0.1,
                "maxOutputTokens": 256
            }
        }')

    curl -s -X POST "${api_url}" \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        | jq -r '.candidates[0].content.parts[0].text // empty'
}


sanitise_command() {
    echo "$1" \
        | sed 's/```[a-zA-Z]*//g; s/```//g' \
        | tr -d '`' \
        | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}


check_dependencies() {
    local missing=()
    for cmd in curl jq; do
        command -v "${cmd}" &>/dev/null || missing+=("${cmd}")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        printf '[Error] Required tools not found: %s\n' "${missing[*]}" >&2
        printf '        Install them and retry.\n' >&2
        exit 1
    fi
}

check_api_key() {
    if [[ -z "${API_KEY}" ]]; then
        printf '[Error] GEMINI_API_KEY is not set.\n' >&2
        printf '        Export it first:  export GEMINI_API_KEY="your_key_here"\n' >&2
        exit 1
    fi
}

# ── Main ─────────────────────────────────────────────────────────
main() {
    check_dependencies
    check_api_key

    printf '╔══════════════════════════════════════════════╗\n'
    printf '║        AI DevOps Agent  (Gemini-powered)     ║\n'
    printf '╚══════════════════════════════════════════════╝\n\n'

    # Long-Term Memory status
    if [[ -f "${MEMORY_FILE}" ]]; then
        printf '[Memory] Preferences loaded from: %s\n' "${MEMORY_FILE}"
        printf '[Memory] Contents:\n'
        sed 's/^/           /' "${MEMORY_FILE}"
    else
        printf '[Memory] No memory file found at %s\n' "${MEMORY_FILE}"
        printf '[Memory] Tip: create agent_memory.txt next to agent.sh to personalise commands.\n'
        printf '[Memory] Example:\n'
        printf '           echo "My preferred editor is vim." > %s\n' "${MEMORY_FILE}"
        printf '           echo "I use DNF to install packages." >> %s\n' "${MEMORY_FILE}"
    fi

    printf '\n[System Prompt] Agent persona loaded (cautious DevOps assistant, non-destructive mode).\n\n'

    # ── Get user intent ──────────────────────────────────────────
    read -r -p "What do you want to do? > " user_intent
    if [[ -z "${user_intent}" ]]; then
        printf '[Error] No intent provided. Exiting.\n' >&2
        exit 1
    fi

    printf '\n[Agent] Querying Gemini (%s)...\n' "${MODEL}"

    # ── Query LLM ────────────────────────────────────────────────
    local raw_output proposed_command
    raw_output=$(query_llm "${user_intent}")
    proposed_command=$(sanitise_command "${raw_output}")

    if [[ -z "${proposed_command}" ]]; then
        printf '[Error] LLM returned an empty response.\n' >&2
        printf '        Check your API key and internet connectivity.\n' >&2
        exit 1
    fi

    # ── Display proposed command ─────────────────────────────────
    printf '\n┌─ Proposed Command ──────────────────────────────────\n'
    printf '│  %s\n' "${proposed_command}"
    printf '└─────────────────────────────────────────────────────\n\n'

    # ── Guardrail: explicit y/n confirmation ─────────────────────
    read -r -p "[Guardrail] Execute this command? (y/n): " confirm
    printf '\n'

    if [[ "${confirm}" =~ ^[Yy]$ ]]; then
        printf '[Agent] Executing...\n'
        printf '══════════════════════════════════════════════════════\n'
        eval "${proposed_command}"
        local exit_code=$?
        printf '══════════════════════════════════════════════════════\n'
        if [[ ${exit_code} -eq 0 ]]; then
            printf '[Agent] Command completed successfully (exit code: 0).\n'
        else
            printf '[Agent] Command exited with code: %d\n' "${exit_code}"
        fi
    else
        printf '[Agent] Execution cancelled by user.\n'
    fi
}

main "$@"
